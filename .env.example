# Flask configuration profile: development, testing, or production
FLASK_CONFIG=development

# Replace this value with a long, random secret outside local development.
SECRET_KEY=replace-with-a-secure-random-value

# Replace with the Neon connection string for this environment.
# Keep Neon's SSL query parameters intact.
DATABASE_URL=postgresql://cryo_user:replace-me@ep-example.neon.invalid/cryo_db?sslmode=require&channel_binding=require

# Used by run.py for local development.
PORT=5000
